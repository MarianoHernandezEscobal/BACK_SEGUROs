{
  "info": {
    "name": "Seguros API",
    "description": "Colección para API Seguros - localhost:3001",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3001"
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "userId",
      "value": ""
    },
    {
      "key": "seguroId",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Usuarios",
      "item": [
        {
          "name": "Crear usuario",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Juan Pérez\",\n  \"email\": \"juan@example.com\",\n  \"password\": \"miPassword123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/users",
              "host": ["{{baseUrl}}"],
              "path": ["users"]
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const json = pm.response.json();",
                  "    if (json.token) {",
                  "        pm.collectionVariables.set('token', json.token);",
                  "    }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"juan@example.com\",\n  \"password\": \"miPassword123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/users/login",
              "host": ["{{baseUrl}}"],
              "path": ["users", "login"]
            },
            "description": "Guarda el token en la variable de colección automáticamente si la respuesta incluye 'token'."
          }
        },
        {
          "name": "Actualizar usuario",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Juan Pérez Actualizado\",\n  \"admin\": false\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/users/{{userId}}",
              "host": ["{{baseUrl}}"],
              "path": ["users", "{{userId}}"]
            }
          }
        },
        {
          "name": "Hacer admin",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/users/{{userId}}/admin",
              "host": ["{{baseUrl}}"],
              "path": ["users", "{{userId}}", "admin"]
            },
            "description": "Requiere token de un usuario admin."
          }
        }
      ]
    },
    {
      "name": "Seguros",
      "item": [
        {
          "name": "Crear seguro",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"María García\",\n  \"phone\": \"+34 612 345 678\",\n  \"tuition\": \"1234 ABC\",\n  \"type\": \"coche\",\n  \"expirationDate\": \"2026-12-31\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/seguros",
              "host": ["{{baseUrl}}"],
              "path": ["seguros"]
            },
            "description": "Requiere token de admin."
          }
        },
        {
          "name": "Listar seguros",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/seguros",
              "host": ["{{baseUrl}}"],
              "path": ["seguros"]
            },
            "description": "Requiere token de admin."
          }
        },
        {
          "name": "Actualizar seguro",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"María García López\",\n  \"phone\": \"+34 698 765 432\",\n  \"tuition\": \"5678 XYZ\",\n  \"type\": \"moto\",\n  \"expirationDate\": \"2027-06-30\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/seguros/{{seguroId}}",
              "host": ["{{baseUrl}}"],
              "path": ["seguros", "{{seguroId}}"]
            },
            "description": "Requiere token de admin. Puedes enviar solo los campos a actualizar."
          }
        }
      ]
    }
  ]
}
